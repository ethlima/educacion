{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2022"],
    "types": ["node", "react", "react-dom", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@site/*": ["./*"],
      "@src/*": ["./src/*"],
      "@theme/*": ["./src/theme/*", ".docusaurus/theme-classic/theme/*"]
    }
  },
  "include": [
    "src/**/*",
    "docs/**/*",
    "blog/**/*",
    "tests/**/*",
    "docusaurus.config.ts",
    "sidebars.ts"
  ],
  "exclude": [".docusaurus", "build", "node_modules"]
}
